Meta.DisplayName=Venice Unleashed
Meta.Description=Battlefield 3 Venice Unleashed Dedicated Server
Meta.OS=Windows, Linux
Meta.Arch=x86_64
Meta.Author=Venice Unleashed Community
Meta.URL=https://veniceunleashed.net/
Meta.DisplayImageSource=steam:1238820
Meta.EndpointURIFormat= 
Meta.ConfigManifest=veniceunleashedconfig.json
Meta.MetaConfigManifest=veniceunleashedmetaconfig.json
Meta.ConfigRoot=veniceunleashed.kvp
Meta.MinAMPVersion=2.6.0.4
Meta.SpecificDockerImage=cubecoders/ampbase:wine-stable
Meta.DockerRequired=False
Meta.ContainerPolicy=SupportedOnWindows, RecommendedOnLinux
Meta.ContainerPolicyReason=The server requires Wine (winehq-stable) and Xvfb to run on Linux. Using a container avoids the need to install these dependencies on the host.
Meta.Prerequisites=[]
Meta.ExtraContainerPackages=[]
Meta.ConfigReleaseState=NotSpecified
Meta.NoCommercialUsage=False
Meta.ConfigVersion=2
Meta.AppConfigId=7b8c9a1e-5f3d-4d7c-9e2f-6a4b8c2d1e3f

App.DisplayName=Venice Unleashed
App.RootDir=./veniceunleashed/
App.BaseDirectory=./veniceunleashed/bf3/
App.ExecutableWin=client\vu.com
App.ExecutableLinux=/usr/bin/xvfb-run
App.WorkingDir=client
App.LinuxCommandLineArgs=--auto-servernum --server-args="-screen 0 1024x768x24" wine "./vu.com"
App.WindowsCommandLineArgs=
App.CommandLineArgs={{$PlatformArgs}} -gamepath "{{$FullBaseDir}}" -serverInstancePath "Z:{{$FullRootDir}}instance" -server -dedicated {{$FormattedArgs}}
App.UseLinuxIOREDIR=False
App.AppSettings={}
App.EnvironmentVariables={"WINEPREFIX":"{{$FullRootDir}}.wine","WINEARCH":"win32","WINEDEBUG":"-all"}
App.CommandLineParameterFormat=-{0} "{1}"
App.CommandLineParameterDelimiter= 
App.ExitMethod=OS_CLOSE
App.ExitTimeout=30
App.ExitString=quit
App.HasWriteableConsole=True
App.HasReadableConsole=True
App.SupportsLiveSettingsChanges=False
App.ApplicationIPBinding=0.0.0.0
App.Ports=@IncludeJson[veniceunleashedports.json]
App.AdminPortRef=0
App.PrimaryApplicationPortRef=GamePort
App.UniversalSleepApplicationUDPPortRef=GamePort
App.MaxUsers=64
App.UseRandomAdminPassword=False
App.RemoteAdminPassword=
App.AdminMethod=STDIO
App.RCONConnectDelaySeconds=5
App.RCONConnectRetrySeconds=5
App.RCONHeartbeatMinutes=0
App.TelnetLoginFormat=login {0}
App.UpdateSources=@IncludeJSON[veniceunleshedupdates.json]
App.Compatibility=None
App.SteamUpdateAnonymousLogin=False
App.SteamForceLoginPrompt=True
App.RapidStartup=False
App.MonitorChildProcessName=^{{$WineBaseDir}}vu\.com.*$
App.SupportsUniversalSleep=True
App.WakeupMode=Any
App.ApplicationReadyMode=RegexMatch

Console.FilterMatchRegex=
Console.FilterMatchReplacement=
Console.ThrowawayMessageRegex=^[0-9a-f]{4}:(fixme|err|warn):.*$
Console.AppReadyRegex=^Server is ready\.$
Console.UserJoinRegex=^User (?<username>.+?) \((?<userid>-?[0-9]+)\) connected from \[::ffff:(?<endpoint>.+?)\]$
Console.UserLeaveRegex=^User (?<username>.+?) \((?<userid>-?[0-9]+)\) disconnected\. Reason: (.+?)$
Console.UserChatRegex=^(?<username>.+?): (?<message>.+)$
Console.UpdateAvailableRegex=
Console.MetricsRegex=
Console.SuppressLogAtStart=False
Console.ActivateLogRegex=

Limits.SleepMode=False
Limits.SleepOnStart=False
Limits.SleepDelayMinutes=5
Limits.DozeDelay=2
Limits.AutoRetryCount=2
Limits.SleepStartThresholdSeconds=25
