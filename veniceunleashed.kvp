#!/bin/bash

################################################################################
# Venice Unleashed BF3 - Complete Universal Setup
# Runs under AMP user (no separate VU user)
# Combines: Server Installation + AMP Template Generation + Cleanup
# AUTO-INSTALLS TEMPLATE TO AMP
# Handles .exe/.zip extraction in Linux
# Uses BF4 Steam App ID (1238820) for display image
# 
# Usage: sudo ./vu-complete-setup.sh [mode]
# Modes: server, template, both (default)
################################################################################

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# Paths - All under AMP home
AMP_USER="amp"
AMP_HOME="/home/amp"
VU_CLIENT_DIR="$AMP_HOME/vu/client"
VU_INSTANCE_DIR="$AMP_HOME/vu/instance"
BF3_DIR="$AMP_HOME/bf3"
WINE_PREFIX="$AMP_HOME/.wine"
TEMPLATE_OUTPUT="${TEMPLATE_OUTPUT:-.}"
AMP_DATA=".ampdata"
AMP_INSTANCE="${AMP_INSTANCE:-ADS01}"
AMP_TEMPLATE_DIR="$AMP_DATA/instances/$AMP_INSTANCE/Plugins/ADSModule/DeploymentTemplates/CubeCoders-AMPTemplates-main"
LOG_FILE="/var/log/vu-complete-setup.log"

# Old VU user (to be removed)
OLD_VU_USER="vu"

################################################################################
# Helper Functions
################################################################################

log() { echo -e "${BLUE}[LOG]${NC} $1" | tee -a "$LOG_FILE"; }
success() { echo -e "${GREEN}[✓]${NC} $1" | tee -a "$LOG_FILE"; }
error() { echo -e "${RED}[✗]${NC} $1" | tee -a "$LOG_FILE"; exit 1; }
warning() { echo -e "${YELLOW}[!]${NC} $1" | tee -a "$LOG_FILE"; }
info() { echo -e "${CYAN}[INFO]${NC} $1"; }

check_root() {
    if [[ $EUID -ne 0 ]]; then
        error "This script must be run as root"
    fi
}

check_os() {
    log "Checking operating system..."
    
    if [ ! -f /etc/os-release ]; then
        error "Cannot determine OS"
    fi
    
    . /etc/os-release
    
    if [[ "$ID" != "debian" && "$ID" != "ubuntu" ]]; then
        error "This script requires Debian or Ubuntu"
    fi
    
    success "OS verified: $PRETTY_NAME"
}

check_amp_instance() {
    log "Checking AMP instance..."
    
    if [ ! -d "$AMP_TEMPLATE_DIR" ]; then
        error "AMP instance not found: $AMP_INSTANCE at $AMP_TEMPLATE_DIR"
    fi
    
    success "AMP instance verified: $AMP_INSTANCE"
}

generate_uuid() {
    local N B
    for (( N=0; N < 16; ++N ))
    do
        B=$(( RANDOM%256 ))
        case $N in
            6) printf '4%x' $(( B%16 )) ;;
            8) printf '%x%x' $(( B/16 )) $(( B%16 )) ;;
            3|5|7|9) printf '%02x-' $B ;;
            *) printf '%02x' $B ;;
        esac
    done
    echo
}

# Extract .exe file (which is actually a ZIP archive)
extract_exe() {
    local exe_file=$1
    local extract_path=$2
    
    log "Extracting: $exe_file to $extract_path"
    
    if [ ! -f "$exe_file" ]; then
        error "File not found: $exe_file"
    fi
    
    # Check if file is actually a ZIP archive
    if file "$exe_file" | grep -q "Zip archive"; then
        log "Detected as ZIP archive, extracting..."
        unzip -q "$exe_file" -d "$extract_path"
        success "Extracted successfully"
    else
        log "File type: $(file $exe_file | cut -d: -f2)"
        error "File is not a valid ZIP archive"
    fi
}

################################################################################
# CLEANUP OLD VU VERSION
################################################################################

cleanup_all() {
    echo ""
    echo -e "${YELLOW}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${YELLOW}║  Cleanup Phase - Removing Old VU User & Services               ║${NC}"
    echo -e "${YELLOW}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Stop old VU services
    local old_services=(
        "vu-bf3" "veniceunleashed" "bf3-vu" "vu-dedicated" 
        "venice-unleashed" "bf3-server" "vu-wine" "vu-server"
    )
    
    log "Stopping old VU services..."
    for service in "${old_services[@]}"; do
        if systemctl list-unit-files 2>/dev/null | grep -q "^${service}"; then
            log "Stopping: $service"
            systemctl stop "$service" 2>/dev/null || true
            systemctl disable "$service" 2>/dev/null || true
        fi
    done
    
    # Remove old service files
    log "Removing old service files..."
    local old_service_files=(
        "/etc/systemd/system/vu-bf3.service"
        "/etc/systemd/system/veniceunleashed.service"
        "/etc/systemd/system/bf3-vu.service"
        "/etc/systemd/system/vu-server.service"
        "/etc/systemd/system/vu-dedicated.service"
        "/lib/systemd/system/vu-bf3.service"
        "/lib/systemd/system/veniceunleashed.service"
    )
    
    for file in "${old_service_files[@]}"; do
        if [ -f "$file" ]; then
            rm -f "$file"
        fi
    done
    
    systemctl daemon-reload 2>/dev/null || true
    
    # Remove old VU user and home directory
    log "Removing old VU user and home directory..."
    if id "$OLD_VU_USER" &>/dev/null; then
        log "Deleting user: $OLD_VU_USER"
        userdel -r "$OLD_VU_USER" 2>/dev/null || true
        success "Old VU user removed"
    fi
    
    # Cleanup old template files from output dir
    log "Cleaning up old template files..."
    
    local patterns=("veniceunleashed*.kvp" "veniceunleashed*.json" "bf3*.kvp" "bf3*.json" "vu*.kvp" "vu*.json")
    
    for pattern in "${patterns[@]}"; do
        for file in "${TEMPLATE_OUTPUT}"/${pattern}; do
            if [ -f "$file" ] 2>/dev/null; then
                local file_time=$(stat -f%m "$file" 2>/dev/null || stat -c%Y "$file" 2>/dev/null || echo 0)
                local current_time=$(date +%s)
                local time_diff=$((current_time - file_time))
                
                if [ "$time_diff" -ge 5 ]; then
                    rm -f "$file"
                fi
            fi
        done
    done
    
    # Cleanup old templates from AMP instance
    log "Removing old templates from AMP instance..."
    if [ -d "$AMP_TEMPLATE_DIR" ]; then
        find "$AMP_TEMPLATE_DIR" -maxdepth 1 \( -name "veniceunleashed*" -o -name "bf3*" -o -name "vu*" \) -type f 2>/dev/null -delete || true
    fi
    
    success "Cleanup completed"
    echo ""
}

################################################################################
# SERVER INSTALLATION PHASE
################################################################################

install_wine() {
    log "Installing Wine..."
    
    if ! dpkg --print-foreign-architectures | grep -q i386; then
        dpkg --add-architecture i386
        apt-get update -qq
    fi
    
    if grep -q "ubuntu" /etc/os-release; then
        log "Adding OpenSUSE Wine repository..."
        cd /tmp
        wget -nc https://download.opensuse.org/repositories/Emulators:/Wine:/Debian/Debian_10/Release.key 2>/dev/null || true
        apt-key add Release.key 2>/dev/null || true
        local ubuntu_ver=$(grep VERSION_ID /etc/os-release | cut -d'"' -f2)
        apt-add-repository "deb https://download.opensuse.org/repositories/Emulators:/Wine:/Debian/xUbuntu_${ubuntu_ver}/ ./" 2>/dev/null || true
    fi
    
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install --install-recommends -y winehq-stable -qq
    
    success "Wine installed: $(wine --version)"
}

install_dependencies() {
    log "Installing dependencies..."
    
    local packages=(
        "xvfb" "unzip" "wget" "curl" "screen" "ca-certificates" "file"
    )
    
    apt-get install -y "${packages[@]}" -qq
    
    # Try to install ncurses
    if apt-cache search "libncurses6:i386" 2>/dev/null | grep -q "libncurses6"; then
        apt-get install -y libncurses6:i386 -qq 2>/dev/null || true
    elif apt-cache search "libncurses5:i386" 2>/dev/null | grep -q "libncurses5"; then
        apt-get install -y libncurses5:i386 -qq 2>/dev/null || true
    fi
    
    apt-get install -y ncurses-base ncurses-bin -qq 2>/dev/null || true
    
    success "Dependencies installed"
}

setup_amp_directories() {
    log "Setting up directories under AMP user..."
    
    # Ensure AMP user exists
    if ! id "$AMP_USER" &>/dev/null; then
        error "AMP user not found. Is AMP installed?"
    fi
    
    mkdir -p "$VU_CLIENT_DIR" "$VU_INSTANCE_DIR" "$BF3_DIR" "$WINE_PREFIX"
    chown -R "$AMP_USER:$AMP_USER" "$AMP_HOME/vu" "$BF3_DIR" "$WINE_PREFIX"
    chmod 750 "$AMP_HOME/vu"
    
    success "Directories created under AMP user"
}

setup_wine_prefix() {
    log "Setting up Wine 32-bit prefix..."
    
    export WINEARCH=win32
    export WINEPREFIX="$WINE_PREFIX"
    
    sudo -u "$AMP_USER" bash -c "WINEARCH=win32 WINEPREFIX=$WINE_PREFIX wine wineboot" 2>&1 | tail -5 | tee -a "$LOG_FILE"
    
    success "Wine prefix configured"
}

install_vcredist() {
    log "Installing Visual C++ redistributable..."
    
    cd /tmp
    if [ ! -f vcredist_x86.exe ]; then
        wget -q https://download.microsoft.com/download/5/D/8/5D8C65CB-C849-4025-8E95-C3966CAFD8AE/vcredist_x86.exe
    fi
    
    export WINEPREFIX="$WINE_PREFIX"
    export WINEARCH=win32
    xvfb-run -a wine /tmp/vcredist_x86.exe /q 2>&1 | tail -3 | tee -a "$LOG_FILE"
    
    success "VC++ redistributable installed"
}

download_vu_files() {
    log "Downloading Venice Unleashed files to: $VU_CLIENT_DIR"
    
    mkdir -p "$VU_CLIENT_DIR"
    
    local vu_zip="/tmp/vu.zip"
    
    # Download to temp location
    if [ ! -f "$vu_zip" ]; then
        log "Downloading VU zip file..."
        wget -q https://veniceunleashed.net/files/vu.zip -O "$vu_zip"
    fi
    
    # Check file type
    log "Checking file type..."
    file "$vu_zip"
    
    # Unzip to specific path
    log "Extracting to: $VU_CLIENT_DIR"
    if file "$vu_zip" | grep -q "Zip archive"; then
        unzip -q "$vu_zip" -d "$VU_CLIENT_DIR"
    else
        error "Downloaded file is not a valid ZIP archive"
    fi
    
    rm -f "$vu_zip"
    
    chown -R "$AMP_USER:$AMP_USER" "$VU_CLIENT_DIR"
    success "VU files downloaded and extracted to $VU_CLIENT_DIR"
}

download_bf3_files() {
    echo ""
    echo -e "${YELLOW}BF3 Files Required${NC}"
    echo ""
    echo "The VU server requires full Battlefield 3 game files (~50GB)"
    echo ""
    echo -e "${CYAN}Method 1: Transfer from Windows machine (RECOMMENDED)${NC}"
    echo "  1. Download BF3 on Windows via Origin/EA App"
    echo "  2. Transfer to server via SCP:"
    echo "    scp -r 'C:\\Program Files\\Battlefield 3\\*' user@server:$BF3_DIR/"
    echo "  3. Or use rsync:"
    echo "    rsync -avz /path/to/BF3/ user@server:$BF3_DIR/"
    echo ""
    echo -e "${CYAN}Method 2: If you have a .7z or .zip backup${NC}"
    echo "  1. Place archive in /tmp/"
    echo "  2. Extract: 7z x /tmp/bf3.7z -o$BF3_DIR/"
    echo "  3. Or: unzip /tmp/bf3.zip -d $BF3_DIR/"
    echo ""
    echo -e "${YELLOW}Path for BF3 files:${NC}"
    echo "  $BF3_DIR"
    echo ""
    
    read -p "Press Enter when BF3 files are in place..."
    
    if [ ! -d "$BF3_DIR" ] || [ -z "$(ls -A $BF3_DIR 2>/dev/null)" ]; then
        warning "BF3 directory is empty or missing!"
        
        # Check for archives in /tmp
        if [ -f "/tmp/bf3.zip" ]; then
            log "Found /tmp/bf3.zip, extracting..."
            extract_exe "/tmp/bf3.zip" "$BF3_DIR"
            chown -R "$AMP_USER:$AMP_USER" "$BF3_DIR"
            success "BF3 files extracted"
        elif [ -f "/tmp/bf3.7z" ]; then
            log "Found /tmp/bf3.7z, extracting..."
            if command -v 7z &> /dev/null; then
                7z x /tmp/bf3.7z -o"$BF3_DIR" > /dev/null
                chown -R "$AMP_USER:$AMP_USER" "$BF3_DIR"
                success "BF3 files extracted"
            else
                warning "7z not found. Install: apt-get install p7zip-full"
                error "Cannot extract 7z file"
            fi
        else
            read -p "Enter path to BF3 files to copy from: " bf3_source
            
            if [ -d "$bf3_source" ]; then
                log "Copying BF3 files from: $bf3_source to $BF3_DIR"
                mkdir -p "$BF3_DIR"
                cp -r "$bf3_source"/* "$BF3_DIR/"
                chown -R "$AMP_USER:$AMP_USER" "$BF3_DIR"
                success "BF3 files copied"
            else
                error "BF3 source path not found: $bf3_source"
            fi
        fi
    else
        success "BF3 files detected at: $BF3_DIR"
        log "Found $(ls -1 $BF3_DIR | wc -l) items in BF3 directory"
    fi
}

setup_server_key() {
    echo ""
    echo -e "${YELLOW}Server Key Required${NC}"
    echo ""
    echo "Generate at: https://veniceunleashed.net/keys"
    echo "Place at: $VU_INSTANCE_DIR/server.key"
    echo ""
    
    read -p "Press Enter when server.key is placed..."
    
    if [ ! -f "$VU_INSTANCE_DIR/server.key" ]; then
        warning "server.key not found"
        read -p "Enter path to server.key: " KEY_PATH
        
        if [ -f "$KEY_PATH" ]; then
            cp "$KEY_PATH" "$VU_INSTANCE_DIR/server.key"
            chown "$AMP_USER:$AMP_USER" "$VU_INSTANCE_DIR/server.key"
            success "Server key placed"
        else
            error "Server key not found: $KEY_PATH"
        fi
    else
        success "Server key found"
    fi
}

activate_game() {
    log "Game activation..."
    
    export WINEPREFIX="$WINE_PREFIX"
    export WINEARCH=win32
    
    echo ""
    echo -e "${YELLOW}Activation Options:${NC}"
    echo "1. Online (requires EA account)"
    echo "2. Token-based"
    echo "3. Skip for now"
    echo ""
    
    read -p "Choose option (1-3): " activate_opt
    
    case $activate_opt in
        1)
            log "Starting online activation..."
            sudo -u "$AMP_USER" bash -c "WINEPREFIX=$WINE_PREFIX WINEARCH=win32 wine $VU_CLIENT_DIR/vu.com -gamepath $BF3_DIR -activate -lsx" 2>&1 | tee -a "$LOG_FILE"
            ;;
        2)
            read -p "Enter EA token: " ea_token
            log "Activating with token..."
            sudo -u "$AMP_USER" bash -c "WINEPREFIX=$WINE_PREFIX WINEARCH=win32 wine $VU_CLIENT_DIR/vu.com -gamepath $BF3_DIR -activate -ea_token $ea_token" 2>&1 | tee -a "$LOG_FILE"
            ;;
        3)
            log "Activation skipped - do manually later"
            ;;
    esac
}

create_systemd_service() {
    log "Creating systemd service..."
    
    cat > /etc/systemd/system/vu-server.service << EOF
[Unit]
Description=Venice Unleashed BF3 Server
After=network.target
Wants=network-online.target

[Service]
Type=forking
User=$AMP_USER
Group=$AMP_USER
WorkingDirectory=$AMP_HOME

Environment="WINEPREFIX=$WINE_PREFIX"
Environment="WINEARCH=win32"

CPUSchedulingPolicy=fifo
CPUSchedulingPriority=20
Nice=-20

ExecStart=/usr/bin/screen -dmS vu /usr/bin/wine $VU_CLIENT_DIR/vu.com -gamepath $BF3_DIR -serverInstancePath "Z:$VU_INSTANCE_DIR" -server -dedicated

ExecStop=/usr/bin/screen -XS vu quit
ExecStop=/usr/bin/wineserver -k

Restart=always
RestartSec=30

StandardOutput=journal
StandardError=journal
SyslogIdentifier=vu-server

[Install]
WantedBy=multi-user.target
EOF
    
    systemctl daemon-reload
    success "Systemd service created"
}

configure_firewall() {
    log "Configuring firewall..."
    
    if command -v ufw &> /dev/null; then
        ufw allow 7948/udp 2>/dev/null || true
        ufw allow 25200/udp 2>/dev/null || true
        ufw allow 47200/tcp 2>/dev/null || true
        success "UFW rules added"
    elif command -v firewall-cmd &> /dev/null; then
        firewall-cmd --permanent --add-port=7948/udp 2>/dev/null || true
        firewall-cmd --permanent --add-port=25200/udp 2>/dev/null || true
        firewall-cmd --permanent --add-port=47200/tcp 2>/dev/null || true
        firewall-cmd --reload 2>/dev/null || true
        success "Firewalld rules added"
    fi
}

install_server() {
    echo ""
    echo -e "${MAGENTA}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║  Server Installation Phase                                     ║${NC}"
    echo -e "${MAGENTA}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    apt-get update -qq
    apt-get upgrade -y -qq
    
    install_wine
    install_dependencies
    setup_amp_directories
    setup_wine_prefix
    install_vcredist
    download_vu_files
    download_bf3_files
    setup_server_key
    activate_game
    create_systemd_service
    configure_firewall
}

################################################################################
# TEMPLATE GENERATION PHASE
################################################################################

generate_template() {
    echo ""
    echo -e "${MAGENTA}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║  AMP Template Generation Phase                                 ║${NC}"
    echo -e "${MAGENTA}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    mkdir -p "$TEMPLATE_OUTPUT"
    
    local app_id=$(generate_uuid)
    local app_lower="veniceunleashed"
    
    # Generate KVP
    log "Generating KVP file..."
    cat > "${TEMPLATE_OUTPUT}/${app_lower}.kvp" << 'EOF'
Meta.DisplayName=Venice Unleashed
Meta.Description=Battlefield 3 Venice Unleashed Dedicated Server
Meta.OS=Windows, Linux
Meta.AarchSupport=Unknown
Meta.Arch=x86_64
Meta.Author=Venice Unleashed Community
Meta.URL=https://veniceunleashed.net
Meta.DisplayImageSource=steam:1238820
Meta.EndpointURIFormat=steam://connect/{ip}:{GenericModule.App.Ports.$ApplicationPort1}
Meta.ConfigManifest=veniceunleashedconfig.json
Meta.MetaConfigManifest=veniceunleashedmetaconfig.json
Meta.ConfigRoot=veniceunleashed.kvp
Meta.MinAMPVersion=2.4.3.0
Meta.SpecificDockerImage=cubecoders/ampbase:debian
Meta.ContainerPolicy=Supported
Meta.ExtraSetupStepsURI=https://docs.veniceunleashed.net/hosting/setup-linux/
Meta.ConfigVersion=1
Meta.AppConfigId=7b8c9a1e-5f3d-4d7c-9e2f-6a4b8c2d1e3f

App.DisplayName=Venice Unleashed
App.RootDir=./veniceunleashed/
App.BaseDirectory=./veniceunleashed/server/
App.ExecutableLinux=server/VeniceUnleashed
App.ExecutableWin=server\VeniceUnleashed.exe
App.WorkingDir=server
App.CommandLineArgs=+ip {{$ApplicationIPBinding}} +port {{$ApplicationPort1}} +queryport {{$ApplicationPort2}} +rconpassword "{{$RemoteAdminPassword}}" +maxusers {{$MaxUsers}} {{$FormattedArgs}}
App.CommandLineParameterFormat=-{0} "{1}"
App.CommandLineParameterDelimiter= 
App.ExitMethod=String
App.ExitString=stop
App.HasWriteableConsole=False
App.HasReadableConsole=True
App.SupportsLiveSettingsChanges=False
App.ApplicationIPBinding=0.0.0.0
App.Ports=@IncludeJson[veniceunleashedports.json]
App.PrimaryApplicationPortRef=ApplicationPort1
App.MaxUsers=64
App.UseRandomAdminPassword=False
App.RemoteAdminPassword=
App.AdminMethod=STDIO
App.TelnetLoginFormat={0}
App.UpdateSources=@IncludeJSON[veniceunleshedupdates.json]
App.Compatibility=None
App.SteamUpdateAnonymousLogin=True
App.MonitorChildProcess=False
App.SupportsUniversalSleep=True
App.WakeupMode=Any
App.ApplicationReadyMode=Immediate
App.RapidStartup=False

Console.FilterMatchRegex=
Console.ThrowawayMessageRegex=^(WARNING|ERROR): Shader.+$
Console.AppReadyRegex=^Server is ready.$
Console.UserJoinRegex=^User (?<username>.+?) \((?<userid>-?[0-9]+)\) connected from \[::ffff:(?<endpoint>.+?)\]$
Console.UserLeaveRegex=^User (?<username>.+?) \((?<userid>-?[0-9]+)\) disconnected\. Reason: (.+?)$
Console.UserChatRegex=^(?<username>.+?): (?<message>.+)$

Limits.SleepOnStart=False
Limits.SleepDelayMinutes=5
Limits.AutoRetryCount=2
EOF
    success "KVP generated"
    
    # Generate ports JSON
    log "Generating ports JSON..."
    cat > "${TEMPLATE_OUTPUT}/${app_lower}ports.json" << 'EOF'
[
    {
        "Protocol": "UDP",
        "Port": 25200,
        "Ref": "ApplicationPort1",
        "Name": "Game Port",
        "Description": "Primary game server port"
    },
    {
        "Protocol": "UDP",
        "Port": 25201,
        "Ref": "ApplicationPort2",
        "Name": "Query Port",
        "Description": "Server query/status port"
    }
]
EOF
    success "Ports JSON generated"
    
    # Generate metaconfig JSON
    log "Generating metaconfig JSON..."
    cat > "${TEMPLATE_OUTPUT}/${app_lower}metaconfig.json" << 'EOF'
[
    {
        "ConfigFile": "server.json",
        "AutoMap": true,
        "ConfigType": "json"
    }
]
EOF
    success "Metaconfig JSON generated"
    
    # Generate config JSON
    log "Generating config JSON..."
    cat > "${TEMPLATE_OUTPUT}/${app_lower}config.json" << 'EOF'
[
    {
        "DisplayName": "Server Name",
        "Category": "VeniceUnleashed:Basic:1",
        "Subcategory": "Basic",
        "Description": "Server name in browser",
        "FieldName": "ServerName",
        "InputType": "text",
        "IsFlagArgument": false,
        "Required": true,
        "DefaultValue": "Venice Unleashed BF3",
        "EnumValues": {}
    },
    {
        "DisplayName": "Max Players",
        "Category": "VeniceUnleashed:Gameplay:3",
        "Subcategory": "Players",
        "Description": "Maximum players",
        "FieldName": "$MaxUsers",
        "InputType": "number",
        "MinValue": "1",
        "MaxValue": "64",
        "IsFlagArgument": false,
        "DefaultValue": "64",
        "EnumValues": {}
    },
    {
        "DisplayName": "Server Password",
        "Category": "VeniceUnleashed:Security:4",
        "Subcategory": "Access",
        "Description": "Server password",
        "FieldName": "ServerPassword",
        "InputType": "password",
        "IsFlagArgument": false,
        "DefaultValue": "",
        "EnumValues": {}
    },
    {
        "DisplayName": "RCON Password",
        "Category": "VeniceUnleashed:Security:4",
        "Subcategory": "Access",
        "Description": "Admin password",
        "FieldName": "$RemoteAdminPassword",
        "InputType": "password",
        "IsFlagArgument": false,
        "DefaultValue": "changeme",
        "EnumValues": {}
    }
]
EOF
    success "Config JSON generated"
    
    # Generate updates JSON
    log "Generating updates JSON..."
    cat > "${TEMPLATE_OUTPUT}/${app_lower}updates.json" << 'EOF'
[
    {
        "UpdateStageName": "Download Venice Unleashed",
        "UpdateSourcePlatform": "Linux",
        "UpdateSource": "FetchURL",
        "UpdateSourceData": "https://github.com/VeniceUnleashed/VeniceUnleashed/releases/download/latest/veniceunleashed-linux.tar.gz",
        "UpdateSourceTarget": "{{$FullBaseDir}}",
        "UnzipUpdateSource": true,
        "OverwriteExistingFiles": true,
        "DeleteAfterExtract": true,
        "SkipOnFailure": false
    }
]
EOF
    success "Updates JSON generated"
    
    echo ""
    success "Template files generated in: $TEMPLATE_OUTPUT"
    echo ""
}

################################################################################
# INSTALL TEMPLATE TO AMP
################################################################################

install_template_to_amp() {
    echo ""
    echo -e "${MAGENTA}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║  Installing Template to AMP Instance                           ║${NC}"
    echo -e "${MAGENTA}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    log "Installing template to: $AMP_TEMPLATE_DIR"
    
    mkdir -p "$AMP_TEMPLATE_DIR"
    
    # Copy KVP and JSON files
    local app_lower="veniceunleashed"
    
    cp "${TEMPLATE_OUTPUT}/${app_lower}.kvp" "$AMP_TEMPLATE_DIR/" 2>/dev/null || error "Failed to copy KVP"
    cp "${TEMPLATE_OUTPUT}/${app_lower}config.json" "$AMP_TEMPLATE_DIR/" 2>/dev/null || error "Failed to copy config"
    cp "${TEMPLATE_OUTPUT}/${app_lower}metaconfig.json" "$AMP_TEMPLATE_DIR/" 2>/dev/null || error "Failed to copy metaconfig"
    cp "${TEMPLATE_OUTPUT}/${app_lower}ports.json" "$AMP_TEMPLATE_DIR/" 2>/dev/null || error "Failed to copy ports"
    cp "${TEMPLATE_OUTPUT}/${app_lower}updates.json" "$AMP_TEMPLATE_DIR/" 2>/dev/null || error "Failed to copy updates"
    
    # Set permissions
    chmod 644 "$AMP_TEMPLATE_DIR"/${app_lower}*
    
    success "Template installed to AMP!"
    echo ""
    echo -e "${YELLOW}Next steps:${NC}"
    echo "1. Restart AMP: systemctl restart amp"
    echo "2. Go to AMP Panel"
    echo "3. Click 'Create Instance'"
    echo "4. Select 'Venice Unleashed' template"
    echo ""
}

################################################################################
# SUMMARY
################################################################################

print_summary() {
    echo ""
    echo -e "${CYAN}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║  Setup Complete!                                               ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    echo -e "${GREEN}Server Setup:${NC}"
    echo "  User: $AMP_USER (AMP user)"
    echo "  Home: $AMP_HOME"
    echo "  Client: $VU_CLIENT_DIR"
    echo "  Instance: $VU_INSTANCE_DIR"
    echo "  BF3: $BF3_DIR"
    echo "  Service: vu-server"
    echo ""
    
    echo -e "${GREEN}Commands:${NC}"
    echo "  Start: systemctl start vu-server"
    echo "  Stop: systemctl stop vu-server"
    echo "  Logs: journalctl -u vu-server -f"
    echo "  Status: systemctl status vu-server"
    echo "  Screen: screen -r vu"
    echo ""
    
    echo -e "${GREEN}AMP Template:${NC}"
    echo "  Status: ✓ Installed"
    echo "  Location: $AMP_TEMPLATE_DIR"
    echo "  Instance: $AMP_INSTANCE"
    echo "  Display Image: Battlefield 4 (Steam ID: 1238820)"
    echo ""
    
    echo -e "${GREEN}Next Steps:${NC}"
    echo "  1. Restart AMP: systemctl restart amp"
    echo "  2. Access AMP Panel"
    echo "  3. Create Instance → Select 'Venice Unleashed'"
    echo "  4. Configure & Start"
    echo ""
    
    echo -e "${GREEN}Cleanup:${NC}"
    echo "  ✓ Old VU user removed"
    echo "  ✓ Old VU home deleted"
    echo "  ✓ Old services stopped & disabled"
    echo "  ✓ AMP user PROTECTED"
    echo ""
}

################################################################################
# Main
################################################################################

main() {
    echo ""
    echo -e "${MAGENTA}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║  Venice Unleashed BF3 - Complete Universal Setup v4.4         ║${NC}"
    echo -e "${MAGENTA}║  Everything under AMP user - Auto-installs to AMP             ║${NC}"
    echo -e "${MAGENTA}║  Server + AMP Template + Auto-Install + Cleanup               ║${NC}"
    echo -e "${MAGENTA}║  Handles .exe/.zip extraction in Linux                         ║${NC}"
    echo -e "${MAGENTA}║  BF4 Steam Image (1238820)                                     ║${NC}"
    echo -e "${MAGENTA}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    touch "$LOG_FILE" 2>/dev/null || LOG_FILE="/tmp/vu-complete-setup.log"
    
    check_root
    check_os
    check_amp_instance
    
    log "Setup started at $(date)"
    
    # Determine mode
    local mode="${1:-both}"
    
    # Always cleanup first
    cleanup_all
    
    case $mode in
        server)
            install_server
            ;;
        template)
            generate_template
            install_template_to_amp
            ;;
        both)
            install_server
            generate_template
            install_template_to_amp
            ;;
        *)
            error "Invalid mode: $mode. Use: server, template, or both"
            ;;
    esac
    
    print_summary
    
    log "Setup completed at $(date)"
}

main "$@"
